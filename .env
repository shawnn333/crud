# Use polling on Windows to avoid watchpack issues with system files such as pagefile.sys
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Which ITaskRepository implementation to use: firebase | localStorage | memory
REACT_APP_TASK_REPOSITORY=firebase

# --- Firebase config -------------------------------------------------
# Get these from: Firebase Console -> Project settings -> General ->
# Your apps -> SDK setup and configuration.
# These are safe to commit (they are not secret keys - access is
# controlled by Firestore/Auth security rules, not by hiding these).
REACT_APP_TASK_REPOSITORY=firebase

